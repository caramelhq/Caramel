# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
# GUILD_ID=your_guild_id_here (optional — restricts slash commands to one guild for testing)

# Owner Configuration (comma-separated list of user IDs)
OWNER_IDS=123456789012345678

# Bot Settings
PREFIX=c!
NODE_ENV=development

# API Settings
API_PORT=4000
API_PREFIX=api

# Database Configuration (PostgreSQL)
# docker-compose exposes PostgreSQL on port 5433
DATABASE_URL=postgresql://admin:secure_password@localhost:5433/Caramellabs_db_dev

# Redis Configuration
# docker-compose exposes Redis on port 6380
REDIS_URL=redis://localhost:6380

# Deploy metadata (set automatically by deploy script)
DEPLOY_VERSION=dev
