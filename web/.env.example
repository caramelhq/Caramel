# Dev bypass — set to "true" to skip OAuth and use mock data
NEXT_PUBLIC_DEV_BYPASS=false

# Public Discord Client ID (used for bot invite links)
NEXT_PUBLIC_DISCORD_CLIENT_ID=

# Copy from root .env and fill in
DATABASE_URL=

# Discord OAuth2 — get from https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# NextAuth
AUTH_SECRET=
NEXTAUTH_URL=

# Redis (same instance as the bot)
REDIS_URL=

# Discord Bot Token (for fetching guild info)
DISCORD_BOT_TOKEN=

# Override the public site URL (e.g. https://caramelhq.xyz)
# Falls back to VERCEL_URL, then https://caramelhq.xyz if unset
# NEXT_PUBLIC_SITE_URL=
